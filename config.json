            }
        ],
        "dubbing": {
            "enabled": true,
            "voice": "vi-VN-HoaiMyNeural",
            "segments": [
                {
                    "time": 0.5,
                    "text": "Chào bạn, đây là video được lồng tiếng tự động.",
                    "translateFrom": false
                },
                {
                    "time": 4.0,
                    "text": "This tool is very powerful",
                    "translateFrom": true
                }
            ]
        }
    }
}
